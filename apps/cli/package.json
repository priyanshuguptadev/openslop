{
	"name": "@openslop/openslop",
	"version": "1.0.0",
	"license": "MIT",
	"private": false,
	"bin": {
		"openslop": "dist/cli.js"
	},
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsc --watch",
		"test": "prettier --check . && xo && ava"
	},
	"files": ["dist"],
	"dependencies": {
		"boxen": "^8.0.1",
		"figlet": "^1.10.0",
		"ink": "6.8.0",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^6.0.0",
		"marked": "^17.0.3",
		"marked-terminal": "^7.3.0",
		"meow": "^11.0.0",
		"react": "19.2.4"
	},
	"devDependencies": {
		"@repo/agent": "workspace:*",
		"@repo/config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/marked": "^6.0.0",
		"@types/marked-terminal": "^6.1.1",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"tsup": "^8.5.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": ["--loader=ts-node/esm"]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"prettier": "@vdemedes/prettier-config"
}
